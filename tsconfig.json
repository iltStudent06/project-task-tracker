{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src",
    "src/vite-env.d.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
